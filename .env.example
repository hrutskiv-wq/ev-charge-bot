# Скопіюйте цей файл у .env та заповніть реальними значеннями.
# .env НІКОЛИ не повинен потрапляти в git (перевірте .gitignore — раніше
# він був у некоректному кодуванні UTF-16 і фактично не працював).

# --- Telegram ---
BOT_TOKEN=
LOGS_CHAT_ID=
PAYMENT_PROVIDER_TOKEN=

# --- Зовнішні API ---
OCM_KEY=
GEMINI_API_KEY=

# --- OCPI (обов'язково, дефолту більше немає — app/services/ocpi/config.py
# впаде при старті, якщо це не задано) ---
OCPI_SECRET_TOKEN=
OCPI_CPO_BASE_URL=http://127.0.0.1:8080
EMSP_BASE_URL=https://evolt.ua

# --- Monobank webhook (X-Sign верифікація, app/api/payments.py) ---
MONOBANK_API_TOKEN=

# --- White-Label білінг операторів ---
# Ключ шифрування еквайринг-токенів операторів (Fernet). БЕЗ НЬОГО білінг
# операторів непрацездатний — застосунок стартує, але видає WARNING, а
# підключення еквайрингу оператору падає з помилкою.
# Згенерувати:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# УВАГА: зміна ключа робить усі вже збережені токени нерозшифровуваними —
# ротація потребує перешифрування operators.monobank_token_encrypted.
ENCRYPTION_KEY=

# Базовий URL еквайрингу Monobank. Лишайте порожнім у проді (дефолт —
# https://api.monobank.ua). Для локальної розробки/тестів вкажіть мок:
#   http://127.0.0.1:8081   (uvicorn mock_monobank:app --port 8081)
MONOBANK_ACQUIRING_BASE_URL=

# Публічна адреса сервісу — банк формує з неї redirectUrl (куди повернути
# водія після оплати) і webHookUrl. Має бути доступна ЗЗОВНІ, не localhost.
# Якщо не задано — береться EMSP_BASE_URL.
PUBLIC_BASE_URL=https://evolt.ua

# --- Купівля kWh-пакетів (buy-side гаманця) через Monobank-еквайринг ---
# id рядка в operators (SERIAL), чиїм еквайринг-токеном виставляються
# інвойси за пакети "Ваучер" -> "Пакет 50/100 кВт·год" — "оператор №0",
# пілот eVolt на собі. Без нього кнопки пакетів відповідають помилкою.
WALLET_OPERATOR_ID=
# @username бота (без @) — куди Monobank поверне водія після оплати пакета.
# Якщо не задано — використовується PUBLIC_BASE_URL (гірше, але не падає).
BOT_USERNAME=
# Старий тестовий флоу купівлі пакета через Telegram Payments
# (bot.send_invoice/PAYMENT_PROVIDER_TOKEN). За замовчуванням вимкнено —
# купівля пакетів тепер іде через Monobank-еквайринг (WALLET_OPERATOR_ID
# вище). "1" вмикає старий флоу назад.
TELEGRAM_PAYMENTS_ENABLED=

# --- PostgreSQL (docker-compose.yml) ---
POSTGRES_USER=ev_admin
POSTGRES_PASSWORD=
POSTGRES_DB=ev_charge_base
DB_URL=postgresql+asyncpg://ev_admin:CHANGE_ME@localhost:5432/ev_charge_base

# --- PWA / CORS (app/main.py), через кому ---
PWA_ALLOWED_ORIGINS=https://evolt.ua
